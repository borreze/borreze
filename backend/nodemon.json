{
    "watch": [
        "src"
    ],
    "ext": "ts,js,json",
    "exec": "ts-node src/server.ts",
    "ignore": [
        "dist",
        "node_modules",
        "seeds"
    ],
    "execMap": {
        "ts": "ts-node -r tsconfig-paths/register"
    },
    "env": {
        "NODE_ENV": "development",
        "PORT": "3000"
    },
    "verbose": true
}