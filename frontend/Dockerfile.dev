FROM node:22-alpine

# Playwright stuff
RUN apk add --no-cache \
    chromium \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont

WORKDIR /app

COPY package*.json ./

RUN npm ci

# Don't `COPY . .` here — let docker-compose mount it

EXPOSE 5173

CMD ["npm", "run", "dev"]
